{
  "version": "1",
  "selectors": [
    "[data-sensitive='true']",
    ".customer-email",
    ".customer-phone",
    ".customer-address",
    ".ssn",
    ".credit-card",
    ".account-number",
    "input[name='email']",
    "input[name='phone']",
    "input[type='tel']",
    ".contact-info",
    "[data-pii='true']"
  ],
  "regex": [
    {
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "flags": "g"
    },
    {
      "pattern": "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
      "flags": "g"
    },
    {
      "pattern": "[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}",
      "flags": "gi"
    },
    {
      "pattern": "\\b\\d{3}[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b",
      "flags": "g"
    }
  ],
  "ignore": {
    "selectors": [
      ".public-data",
      "#marketing-section *",
      ".footer-contact",
      "input[name='support_email']",
      "[data-public='true']"
    ],
    "regex": [
      {
        "pattern": "support@mycompany\\.com",
        "flags": "i"
      },
      {
        "pattern": "sales@mycompany\\.com",
        "flags": "i"
      },
      {
        "pattern": "demo[0-9]+@example\\.com",
        "flags": "i"
      },
      {
        "pattern": "test@test\\.com",
        "flags": "i"
      }
    ]
  }
}
