{
  "version": "1",
  "selectors": [
    "[data-sensitive='true']",
    ".patient-name",
    ".patient-id",
    ".medical-record",
    ".diagnosis",
    ".ssn",
    ".insurance-number",
    "input[name='patient_name']",
    "input[name='mrn']",
    "[data-phi='true']"
  ],
  "regex": [
    {
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "flags": "g"
    },
    {
      "pattern": "MRN[:\\s]?\\d{6,10}",
      "flags": "gi"
    },
    {
      "pattern": "[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}",
      "flags": "gi"
    },
    {
      "pattern": "\\b\\d{3}[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b",
      "flags": "g"
    }
  ],
  "ignore": {
    "selectors": [
      ".public-data",
      ".hospital-info",
      ".department-contact"
    ],
    "regex": [
      {
        "pattern": "info@hospital\\.com",
        "flags": "i"
      },
      {
        "pattern": "appointments@hospital\\.com",
        "flags": "i"
      }
    ]
  }
}
